{
    "name": "pict-section-formeditor",
    "version": "1.0.15",
    "description": "Pict visual editor for pict-section-form configurations",
    "main": "source/Pict-Section-FormEditor.js",
    "scripts": {
        "start": "node source/Pict-Section-FormEditor.js",
        "test": "npx quack test",
        "tests": "npx quack test -g",
        "coverage": "npx quack coverage",
        "build": "npx quack build",
        "example": "npx quack examples",
        "docs": "npx quack prepare-docs ./docs -d ./modules",
        "docs-serve": "npx quack docs-serve ./docs"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/stevenvelozo/pict-section-formeditor.git"
    },
    "author": "steven velozo <steven@velozo.com>",
    "license": "MIT",
    "bugs": {
        "url": "https://github.com/stevenvelozo/pict-section-formeditor/issues"
    },
    "homepage": "https://github.com/stevenvelozo/pict-section-formeditor#readme",
    "dependencies": {
        "pict-section-code": "^1.0.11",
        "pict-section-content": "^1.0.5",
        "pict-section-flow": "^1.0.1",
        "pict-section-form": "^1.0.199",
        "pict-section-markdowneditor": "^1.0.15",
        "pict-section-modal": "^1.1.4",
        "pict-section-objecteditor": "^1.0.3",
        "pict-view": "^1.0.68"
    },
    "devDependencies": {
        "pict": "^1.0.372",
        "pict-docuserve": "^1.4.2",
        "quackage": "^1.2.5"
    },
    "mocha": {
        "diff": true,
        "extension": [
            "js"
        ],
        "package": "./package.json",
        "reporter": "spec",
        "slow": "75",
        "timeout": "5000",
        "ui": "tdd",
        "watch-files": [
            "source/**/*.js",
            "test/**/*.js"
        ],
        "watch-ignore": [
            "lib/vendor"
        ]
    }
}
